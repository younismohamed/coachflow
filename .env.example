# ============================================================
# CoachFlow Environment Variables
# Copy to .env.local — NEVER commit .env.local to git
# ============================================================

# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Service role key — server-only, NEVER expose to client
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# --- App ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
# In production: NEXT_PUBLIC_APP_URL=https://coachflow.yourcompany.com

# --- Resend (Email) ---
RESEND_API_KEY=re_your_resend_api_key
RESEND_FROM_EMAIL=coaching@yourcompany.com

# --- Cron Security ---
# Random secret for protecting cron endpoints
CRON_SECRET=generate-a-random-32-char-string-here
